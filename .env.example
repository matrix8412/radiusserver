# ============================================================
# RadiusServer - Environment Configuration
# ============================================================
# Copy this file to .env and adjust values before deployment.
# NEVER commit the .env file to version control.
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=radius
POSTGRES_USER=radius
POSTGRES_PASSWORD=ChangeMeNow_pg2025!

# --- Application ---
# Secret used to sign JWT tokens (MUST be changed in production)
JWT_SECRET=ChangeMeNow_jwt_super_secret_key_2025!
# Token lifetime
JWT_EXPIRES_IN=1h
# Port the web UI / API listens on inside the container
APP_PORT=3000
# Node environment
NODE_ENV=production

# --- Internal Communication ---
# Shared secret between FreeRADIUS exec module and the backend API
INTERNAL_SECRET=ChangeMeNow_internal_secret_2025!

# --- FreeRADIUS ---
# Default RADIUS shared secret for test clients (override per-NAS in UI)
RADIUS_SECRET=testing123
# RadSec toggle (true/false)
RADSEC_ENABLED=true

# --- Session / Security ---
# CSRF cookie secret
CSRF_SECRET=ChangeMeNow_csrf_secret_2025!
# Bcrypt rounds for admin password hashing
BCRYPT_ROUNDS=12

# --- Logging ---
# Log level: debug, info, warn, error
LOG_LEVEL=info

# --- Backup ---
BACKUP_DIR=/backup

# --- Default Admin (created on first run) ---
DEFAULT_ADMIN_USER=admin
DEFAULT_ADMIN_PASSWORD=ChangeMe123!

# --- TZ ---
TZ=UTC
